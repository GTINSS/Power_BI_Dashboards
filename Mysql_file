/* Find the total Score of each Country */

SELECT 
	country, 
	SUM(score) AS total_score
FROM customers
GROUP BY country

/* Find the total Score and total number of customers 
for each country */

SELECT 
	country,
	SUM(score) AS total_score,
	COUNT(id) AS total_customers
FROM customers
