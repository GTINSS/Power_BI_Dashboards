-- EOMONTH,DATETRUNC,DATENAME,DATEPART,YEAR,MONTH,DAY

SELECT
OrderID,
creationTime,
-- EOMONTH
	EOMONTH(creationTime) AS eom_eom,
-- DATETRUNC 
	DATETRUNC(MINUTE,CreationTime) AS mns_dt,
	DATETRUNC(HOUR,CreationTime) AS hr_dt,
	DATETRUNC(DAY,CreationTime) AS dy_dt,
-- DATENAME
	DATENAME(YEAR,CreationTime) AS yr_dn,
	DATENAME(MONTH,CreationTime) AS mm_dn,
	DATENAME(WEEKDAY,CreationTime) AS dy_dn,
	DATENAME(DAY,CreationTime) AS dy_dn,
-- DATEPART
	DATEPART(WEEKDAY,CreationTime) AS wkdy_dp,
	DATEPART(WEEK,CreationTime) AS wk_dp,
	DATEPART(QUARTER,CreationTime)AS qt_dp,
	DATEPART(YEAR,CreationTime) AS yr_dp,
	DATEPART(MONTH,CreationTime) AS mm_dp,
	DATEPART(DAY,CreationTime) AS day_dp,
	DATEPART(HOUR,CreationTime) AS hr_dp,
	DATEPART(MINUTE,CreationTime) AS mns_dp,
	DATEPART(SECOND,CreationTime) AS sec_dp,
-- YEAR,MONTH,DAY
	YEAR(CreationTime) AS year,
	MONTH(CreationTime) AS month,
	DAY(CreationTime) AS day
FROM Sales.Orders;

SELECT
CAST(DATETRUNC(MONTH,CreationTime) AS DATE)
FROM sales.Orders


SELECT
DATETRUNC(MONTH,CreationTime) AS creation,
COUNT(*)
FROM Sales.Orders
GROUP BY DATETRUNC(MONTH,CreationTime);

